{
  "name": "personal-3d-site",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "scripts": {
    "analyze": "tsc && vite build --mode analyze",
    "dev": "vite",
    "dev:codex": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc && vite build",
    "firebase:deploy": "firebase deploy --only hosting",
    "firebase:emulate": "firebase emulators:start --only hosting",
    "lhci": "lhci autorun",
    "preview": "vite preview",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "lint": "eslint .",
    "check": "tsc && vite build && eslint .",
    "check:quick": "tsc && eslint .",
    "test:smoke": "playwright test",
    "test:visual": "playwright test --project=chromium"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "firebase": "^12.16.0",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1",
    "web-vitals": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-tools": "^15.24.0",
    "globals": "^17.7.0",
    "pngjs": "^7.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~7.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5"
  }
}
