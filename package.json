{
  "name": "personal-3d-site",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "scripts": {
    "analyze": "tsc && vite build --mode analyze",
    "dev": "vite",
    "dev:codex": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "tsc && vite build",
    "firebase:deploy": "firebase deploy --only hosting",
    "firebase:emulate": "firebase emulators:start --only hosting",
    "lhci": "lhci autorun",
    "preview": "vite preview",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "lint": "eslint .",
    "check": "tsc && vite build && eslint .",
    "check:quick": "tsc && eslint .",
    "test:smoke": "playwright test",
    "test:visual": "playwright test --project=chromium"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "firebase": "^12.15.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "three": "^0.171.0",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "firebase-tools": "^15.22.3",
    "globals": "^15.14.0",
    "pngjs": "^7.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5"
  }
}
